{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jeffreyhill-ai/agentic-financial-ai-patterns/schemas/source-linked-fact.schema.json",
  "title": "SourceLinkedFinancialFact",
  "type": "object",
  "required": [
    "fact_id",
    "fact_type",
    "value",
    "source",
    "confidence",
    "review_status",
    "lineage"
  ],
  "properties": {
    "fact_id": { "type": "string" },
    "fact_type": { "type": "string", "examples": ["asset.balance", "liability.balance", "income.recurring"] },
    "label": { "type": "string" },
    "value": {},
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "as_of_date": { "type": "string", "format": "date" },
    "source": {
      "type": "object",
      "required": ["source_type", "source_id", "reference"],
      "properties": {
        "source_type": { "type": "string", "enum": ["document", "provider_dataset", "manual_entry", "system_calculation"] },
        "provider": { "type": "string" },
        "dataset": { "type": "string" },
        "source_id": { "type": "string" },
        "reference": { "type": "string" },
        "excerpt": { "type": "string" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_status": {
      "type": "string",
      "enum": ["proposed", "needs_review", "approved", "corrected", "rejected"]
    },
    "lineage": {
      "type": "object",
      "properties": {
        "extraction_method": { "type": "string" },
        "model_or_rule_version": { "type": "string" },
        "transformation_version": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
